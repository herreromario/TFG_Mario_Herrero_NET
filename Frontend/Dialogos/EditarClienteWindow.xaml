<Window x:Class="StockMeal.Frontend.Dialogos.EditarClienteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editar cliente"
        Height="360"
        Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#232323">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Editar cliente" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,0,0,16"/>
        <TextBlock Grid.Row="1" Text="Nombre" Foreground="White"/>
        <TextBox Grid.Row="2" Margin="0,4,0,10" Text="{Binding Nombre, UpdateSourceTrigger=PropertyChanged}"/>
        <TextBlock Grid.Row="3" Text="Apellido" Foreground="White"/>
        <TextBox Grid.Row="4" Margin="0,4,0,10" Text="{Binding Apellido, UpdateSourceTrigger=PropertyChanged}"/>
        <TextBlock Grid.Row="5" Text="Teléfono" Foreground="White"/>
        <TextBox Grid.Row="6" Margin="0,4,0,10" Text="{Binding Telefono, UpdateSourceTrigger=PropertyChanged}"/>
        <TextBlock Grid.Row="7" Text="Tipo cliente" Foreground="White"/>
        <ComboBox Grid.Row="8" Margin="0,4,0,10" x:Name="TipoClienteCombo"/>

        <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancelar" Width="120" Height="36" Margin="0,0,10,0" Click="Cancelar_Click"/>
            <Button Content="Actualizar" Width="120" Height="36" Click="Actualizar_Click"/>
        </StackPanel>
    </Grid>
</Window>
