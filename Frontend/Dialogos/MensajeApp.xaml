<Window x:Class="StockMeal.Frontend.Dialogos.MensajeApp"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Width="430"
        Height="220">
    <Border Background="#2A2A2A" CornerRadius="14" Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="TituloText" Foreground="White" FontSize="22" FontWeight="Bold"/>
            <TextBlock x:Name="MensajeText" Grid.Row="1" Foreground="White" Margin="0,12,0,0" TextWrapping="Wrap"/>
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                <Button x:Name="BtnCancelar" Content="Cancelar" Width="110" Margin="0,0,10,0" Click="Cancelar_Click"/>
                <Button x:Name="BtnAceptar" Content="Aceptar" Width="110" Click="Aceptar_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
