<UserControl x:Class="StockMeal.Frontend.UserControls.UCAjustesStock"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             Loaded="UCAjustesStock_Loaded"
             mc:Ignorable="d"
             d:DesignWidth="1560"
             d:DesignHeight="912">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Alertas y Ajustes de Stock"
                   FontSize="36"
                   FontWeight="Bold"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   Margin="0,20,0,20"/>

        <TextBlock Grid.Row="1"
                   Margin="20,0,20,10"
                   Foreground="White"
                   Text="Edita stock disponible y stock mínimo. Selecciona una fila y pulsa Guardar cambios."/>

        <DataGrid x:Name="dgStock"
                  Grid.Row="2"
                  ItemsSource="{Binding Ingredientes}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  ColumnWidth="*"
                  Margin="0,0,0,12">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Ingrediente" Binding="{Binding Nombre}" IsReadOnly="True"/>
                <DataGridTextColumn Header="Unidad" Binding="{Binding Unidad}" IsReadOnly="True"/>
                <DataGridTextColumn Header="Stock disponible" Binding="{Binding StockDisponible, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="Stock mínimo" Binding="{Binding StockMinimo, UpdateSourceTrigger=PropertyChanged}"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Guardar cambios fila seleccionada"
                    Width="280"
                    Height="44"
                    Margin="0,0,12,0"
                    Click="GuardarFila_Click"
                    Style="{StaticResource PrimaryButtonStyle}"/>
            <Button Content="Refrescar"
                    Width="140"
                    Height="44"
                    Click="Refrescar_Click"
                    Style="{StaticResource PrimaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</UserControl>
