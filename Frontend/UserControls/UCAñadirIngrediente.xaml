<UserControl x:Class="StockMeal.Frontend.UserControls.UCAñadirIngrediente"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:local="clr-namespace:StockMeal.Frontend.UserControls"
             Loaded="AñadirIngrediente_Loaded"
             mc:Ignorable="d"
             d:DesignWidth="1560"
             d:DesignHeight="912">
    
    <Grid VerticalAlignment="Center">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5*"/>
            <ColumnDefinition Width="5*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TITULO -->
        <TextBlock 
            Grid.ColumnSpan="2"
            Text="Añadir Nuevo Ingrediente"
            FontSize="36"
            FontWeight="Bold"
            Foreground="White"
            HorizontalAlignment="Center"
            Margin="0,20,0,40"/>

        <!-- NOMBRE -->
        <TextBox 
            Text="{Binding ingrediente.Nombre, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors = True, NotifyOnValidationError = True}"
            Grid.Row="1"
            Margin="0,0,50,20"
            FontSize="20"
            Width="300"
            HorizontalAlignment="Right"
            materialDesign:HintAssist.Hint="Nombre"
            FontWeight="Bold"
            Style="{StaticResource MaterialDesignFloatingHintTextBox}"
            Foreground="White"/>

        <!-- UNIDAD -->
        <ComboBox
            ItemsSource="{Binding listaUnidades}"
            SelectedItem="{Binding ingrediente.Unidad, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors = True, NotifyOnValidationError = True}"
            Grid.Column="0"
            Grid.Row="2"
            Margin="0,0,50,20"
            FontSize="20"
            Width="300"
            HorizontalAlignment="Right"
            materialDesign:HintAssist.Hint="Unidad"
            Style="{StaticResource MaterialDesignFloatingHintComboBox}"
            Foreground="White"/>

        <!-- STOCK DISPONIBLE -->
        <TextBox 
            Text="{Binding ingrediente.StockDisponible, UpdateSourceTrigger=PropertyChanged,ValidatesOnDataErrors = True, NotifyOnValidationError = True}"
            Grid.Column="0"
            Grid.Row="3"
            Margin="0,0,50,20"
            FontSize="20"
            Width="300"
            HorizontalAlignment="Right"
            materialDesign:HintAssist.Hint="Stock Disponible"
            Style="{StaticResource MaterialDesignFloatingHintTextBox}"
            Foreground="White"/>

        <!-- DESCRIPCIÓN -->
        <TextBox 
            Text="{Binding ingrediente.Descripcion}"
            Grid.Column="1"
            Grid.Row="1"
            Margin="50,0,0,20"
            FontSize="20"
            Width="300"
            HorizontalAlignment="Left"
            materialDesign:HintAssist.Hint="Descripción"
            Style="{StaticResource MaterialDesignFloatingHintTextBox}"
            Foreground="White"/>

        <!-- PRECIO -->
        <TextBox 
            Text="{Binding ingrediente.Precio, UpdateSourceTrigger=LostFocus, StringFormat=F2, ValidatesOnExceptions=True, NotifyOnValidationError=True}"
            Grid.Column="1"
            Grid.Row="2"
            Margin="50,0,0,20"
            FontSize="20"
            Width="300"
            HorizontalAlignment="Left"
            materialDesign:HintAssist.Hint="Precio"
            Style="{StaticResource MaterialDesignFloatingHintTextBox}"
            Foreground="White"/>

        <!-- STOCK MÍNIMO -->
        <TextBox 
            Text="{Binding ingrediente.StockMinimo, UpdateSourceTrigger=PropertyChanged,ValidatesOnDataErrors = True, NotifyOnValidationError = True}"
            Grid.Column="1"
            Grid.Row="3"
            Margin="50,0,0,20"
            FontSize="20"
            Width="300"
            HorizontalAlignment="Left"
            materialDesign:HintAssist.Hint="Stock Mínimo"
            Style="{StaticResource MaterialDesignFloatingHintTextBox}"
            Foreground="White"/>

        <!-- BOTÓN AÑADIR -->
        <Button
            x:Name="btnAñadirIngrediente"
            Click="btnAñadirIngrediente_Click"
            IsEnabled="{Binding HasErrors}"
            Grid.Column="2"
            Grid.Row="4"
            Content="Añadir Ingrediente"
            Width="200"
            Height="50"
            FontSize="20"
            HorizontalAlignment="Left"
            Margin="50,20,0,0"
            Style="{StaticResource PrimaryButtonStyle}"/>

        <!-- BOTÓN CANCELAR -->
        <Button
            x:Name="btnCancelar"
            Click="btnCancelar_Click"
            Grid.Row="4"
            Content="Cancelar"
            Width="200"
            Height="50"
            FontSize="20"
            HorizontalAlignment="Right"
            Margin="0,20,50,0"
            Style="{StaticResource PrimaryButtonStyle}"/>


    </Grid>
</UserControl>
