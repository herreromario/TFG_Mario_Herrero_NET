<UserControl x:Class="StockMeal.Frontend.UserControls.UCAñadirCompra"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Loaded="AñadirCompra_Loaded"
             mc:Ignorable="d"
             d:DesignWidth="1560"
             d:DesignHeight="912">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Nueva Compra" FontSize="36" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,20,0,24"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
            <ComboBox Width="320" Margin="0,0,16,0" FontSize="16"
                      ItemsSource="{Binding listaProveedores}"
                      DisplayMemberPath="Nombre"
                      SelectedValuePath="IdProveedor"
                      SelectedValue="{Binding compra.IdProveedor, UpdateSourceTrigger=PropertyChanged}"
                      materialDesign:HintAssist.Hint="Proveedor"/>
            <DatePicker Width="220" SelectedDate="{Binding compra.Fecha, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBox Width="220" Margin="16,0,0,0" FontSize="16"
                     Text="{Binding compra.ImporteTotal, StringFormat=F2}"
                     IsReadOnly="True"
                     materialDesign:HintAssist.Hint="Importe total"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,16">
            <ComboBox Width="380" Margin="0,0,16,0" FontSize="16"
                      ItemsSource="{Binding listaIngredientesCompra}"
                      DisplayMemberPath="Nombre"
                      SelectedValuePath="IdProducto"
                      SelectedValue="{Binding idProductoDetalleSeleccionado, UpdateSourceTrigger=PropertyChanged}"
                      SelectionChanged="cmbProducto_SelectionChanged"
                      materialDesign:HintAssist.Hint="Ingrediente"/>
            <TextBox Width="120" Margin="0,0,16,0" FontSize="16"
                     Text="{Binding cantidadDetalle, UpdateSourceTrigger=PropertyChanged}"
                     materialDesign:HintAssist.Hint="Cantidad"/>
            <TextBox Width="160" Margin="0,0,16,0" FontSize="16"
                     Text="{Binding precioUnitarioDetalle, UpdateSourceTrigger=PropertyChanged}"
                     materialDesign:HintAssist.Hint="Precio unitario"/>
            <Button Content="Añadir línea" Width="160" Click="btnAñadirDetalle_Click" Style="{StaticResource PrimaryButtonStyle}"/>
        </StackPanel>

        <DataGrid Grid.Row="3" ItemsSource="{Binding detallesCompra}" AutoGenerateColumns="False" CanUserAddRows="False" ColumnWidth="*" Margin="0,0,0,16">
            <DataGrid.Columns>
                <DataGridTextColumn Header="IdProducto" Binding="{Binding IdProducto}"/>
                <DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad}"/>
                <DataGridTextColumn Header="Precio unitario" Binding="{Binding PrecioUnitario}"/>
                <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal}"/>
                <DataGridTemplateColumn Header="Acciones">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Quitar" Click="btnQuitarDetalle_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Guardar compra" Width="180" Height="48" Margin="0,0,20,0" Click="btnGuardar_Click" Style="{StaticResource PrimaryButtonStyle}"/>
            <Button Content="Cancelar" Width="180" Height="48" Click="btnCancelar_Click" Style="{StaticResource PrimaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</UserControl>
