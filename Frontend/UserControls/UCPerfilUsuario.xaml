<UserControl x:Class="StockMeal.Frontend.UserControls.UCPerfilUsuario"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             Loaded="UCPerfilUsuario_Loaded"
             mc:Ignorable="d"
             d:DesignWidth="1560"
             d:DesignHeight="912">
    <Grid VerticalAlignment="Center">
        <StackPanel Width="520">
            <TextBlock Text="Mi cuenta" FontSize="36" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,20,0,40"/>
            <TextBox Margin="0,0,0,16" FontSize="20" Text="{Binding nombre, UpdateSourceTrigger=PropertyChanged}" />
            <TextBox Margin="0,0,0,16" FontSize="20" Text="{Binding apellido, UpdateSourceTrigger=PropertyChanged}" />
            <TextBox Margin="0,0,0,16" FontSize="20" Text="{Binding usuario, UpdateSourceTrigger=PropertyChanged}" />
            <PasswordBox x:Name="txtPasswordNueva" Margin="0,0,0,16" FontSize="20"/>
            <Button Content="Guardar cambios" Width="220" Height="46" HorizontalAlignment="Center" Click="Guardar_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
