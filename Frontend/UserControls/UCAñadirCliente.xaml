<UserControl x:Class="StockMeal.Frontend.UserControls.UCAñadirCliente"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Loaded="AñadirCliente_Loaded"
             mc:Ignorable="d"
             d:DesignWidth="1560"
             d:DesignHeight="912">
    <Grid VerticalAlignment="Center">
        <StackPanel Width="460">
            <TextBlock Text="Añadir Cliente" FontSize="36" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,20,0,40"/>
            <TextBox Margin="0,0,0,16" FontSize="20" Text="{Binding cliente.Nombre, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Nombre" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Foreground="White"/>
            <TextBox Margin="0,0,0,16" FontSize="20" Text="{Binding cliente.Apellido, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Apellido" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Foreground="White"/>
            <TextBox Margin="0,0,0,16" FontSize="20" Text="{Binding cliente.Telefono, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Teléfono" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Foreground="White"/>
            <ComboBox Margin="0,0,0,16" FontSize="18" ItemsSource="{Binding listaTiposCliente}" SelectedItem="{Binding cliente.TipoCliente, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Tipo cliente"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button Content="Guardar" Width="180" Height="48" Margin="0,0,20,0" Click="btnGuardar_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                <Button Content="Cancelar" Width="180" Height="48" Click="btnCancelar_Click" Style="{StaticResource PrimaryButtonStyle}"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
